{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./static/js",
    "rootDir": "./static/js",
    "allowJs": true,
    "types": ["jest"]
  },
  "include": ["static/js/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
